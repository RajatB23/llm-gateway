# Copy to .env on the droplet — never commit real keys.
# cp .env.example .env && nano .env

# Required for DigitalOcean Gradient routes (doo_v1_...)
DO_API_KEY=your_digitalocean_model_access_key_here

# Optional direct provider keys (only if using non-DO routes)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# HTTP port (default 8080)
SERVER_PORT=8080

# JVM heap — defaults are set in deploy/docker-compose.prod.yml for 512MB droplets
# JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseSerialGC -XX:MaxMetaspaceSize=128m
